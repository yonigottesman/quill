// Module map for `import llama` against the Homebrew-installed llama.cpp
// (/opt/homebrew). This is used ONLY by the standalone test harness
// (scripts/test-prompt.sh), which compiles the inference code directly against
// Homebrew libllama for fast iteration.
//
// The APP no longer uses this: it embeds Frameworks/llama.xcframework (built by
// scripts/build-xcframework.sh) and `import llama` resolves to the framework's
// own bundled module map. So the app needs no Homebrew install; only the test
// harness still does.
module llama [system] {
    header "/opt/homebrew/include/llama.h"
    export *
}
